whitespace = /[ \n\r\t\f]+/

label = /[a-zA-Z0-9\-_.]+/

math_symbol = /[0-9A-Za-z!"#%&`()*+,\-./:;<=>?@[\\\]^_'{|}~]+/

comment = /$\([ \n\r\t\f]+[ \n\r\t\f0-9A-Za-z!"#$%&`()*+,\-./:;<=>?@[\\\]^_'{|}~]+[ \n\r\t\f]+$\)/

dollar_lbrace = /${/
dollar_rbrace = /$}/
dollar_c = /$c/
dollar_v = /$v/
dollar_f = /$f/
dollar_e = /$d/
dollar_a = /$a/
dollar_p = /$p/
dollar_period = /$./
dollar_equal = /$=/
# dollar_lparen = /$(/
# dollar_rparen = /$)/
dollar_lbracket = /$[/
dollar_rbracket = /$]/
